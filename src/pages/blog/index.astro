---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout title="Blog — Ray Martinez" description="Writing about AI, engineering, and building things.">
  <a href="/" class="text-sm text-accent hover:underline">&larr; Back</a>

  <section>
    <h1 class="text-3xl font-bold tracking-tight mb-8">Blog</h1>
    <ul class="space-y-8">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`} class="group block">
            <time class="text-sm text-gray-400" datetime={post.data.date.toISOString().slice(0, 10)}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h2 class="text-xl font-semibold group-hover:text-accent transition-colors">{post.data.title}</h2>
            <p class="text-gray-500 mt-1">{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
