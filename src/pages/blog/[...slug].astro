---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — Ray Martinez`} description={post.data.description}>
  <a href="/blog" class="text-sm text-accent hover:underline">&larr; All posts</a>

  <article class="prose prose-gray max-w-none">
    <header class="not-prose mb-8">
      <time class="text-sm text-gray-400" datetime={post.data.date.toISOString().slice(0, 10)}>
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="text-3xl font-bold tracking-tight mt-1">{post.data.title}</h1>
    </header>
    <Content />
  </article>
</Layout>
